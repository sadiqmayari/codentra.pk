# Claude Code (CRITICAL - prevents worktree pollution)
.claude/

# Environment files (CRITICAL - never commit DB passwords)
.env
.env.*
!.env.example

# PHP / Composer
/vendor/
composer.lock

# Project runtime data (should not be in repo)
/cache/pages/*
!/cache/pages/.gitkeep
/cache/sitemap.xml
/uploads/*
!/uploads/.gitkeep
!/uploads/.htaccess
!/uploads/posts/
/uploads/posts/*
!/uploads/posts/.gitkeep
/storage/*
!/storage/.gitkeep
*.log
*.sqlite
*.db
error_log

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE / editors
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-*

# Backups
*.bak
*.backup
*.orig

# Node (only if you ever add a build step)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
*.pem