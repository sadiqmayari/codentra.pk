# ── URL Rewriting ────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Block access to hidden/sensitive files (these run unconditionally)
    RewriteRule ^\.env                  - [F,L]
    RewriteRule ^config/                - [F,L]
    RewriteRule ^src/                   - [F,L]
    RewriteRule ^cache/                 - [F,L]
    RewriteRule ^sql/                   - [F,L]
    RewriteRule ^tools/                 - [F,L]

    # Allow direct access to real files/dirs (CSS, JS, fonts, images)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route everything else to index.php
    RewriteRule ^ index.php [QSA,L]
</IfModule>