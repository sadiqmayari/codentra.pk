# ── URL Rewriting ────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Block access to hidden/sensitive files (these run unconditionally)
    RewriteRule ^\.env                  - [F,L]
    RewriteRule ^config/                - [F,L]
    RewriteRule ^src/                   - [F,L]
    RewriteRule ^cache/                 - [F,L]
    RewriteRule ^sql/                   - [F,L]
    RewriteRule ^tools/                 - [F,L]

    # Allow direct access to real files/dirs (CSS, JS, fonts, images)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route everything else to index.php
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# ── Cloudflare / proxy awareness ──────────────────────────────────────────────
# When Cloudflare terminates SSL, the origin connection is HTTP. Apache won't
# set HTTPS=on, so PHP code that checks $_SERVER['HTTPS'] thinks the request
# is insecure. Trust the X-Forwarded-Proto header to fix that.
<IfModule mod_setenvif.c>
    SetEnvIfNoCase X-Forwarded-Proto "https" HTTPS=on
</IfModule>

# ── Compression ───────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json application/xml text/plain
</IfModule>

# ── Browser Caching (Expires) ────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html              "access plus 0 seconds"
    ExpiresByType text/css               "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/webp             "access plus 1 year"
    ExpiresByType image/png              "access plus 1 year"
    ExpiresByType image/jpeg             "access plus 1 year"
    ExpiresByType image/svg+xml          "access plus 1 year"
    ExpiresByType font/woff2             "access plus 1 year"
    ExpiresByType application/xml        "access plus 1 day"
</IfModule>

# ── Immutable cache for fingerprinted (?v=) static assets ────────────────────
# These are versioned via ?v=filemtime in markup, so the URL changes whenever
# the file changes — safe to mark immutable.
<IfModule mod_headers.c>
    <FilesMatch "\.(?:css|js|woff2|webp|svg|jpg|jpeg|png|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(?:html|php)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>

    # Security headers
    Header always set X-Content-Type-Options    "nosniff"
    Header always set X-Frame-Options           "SAMEORIGIN"
    Header always set Referrer-Policy           "strict-origin-when-cross-origin"
    Header always set Permissions-Policy        "camera=(), microphone=(), geolocation=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Content Security Policy — script CDNs are allow-listed explicitly:
    #   cdnjs.cloudflare.com  → Three.js (home hero)
    #   cdn.jsdelivr.net      → Chart.js (admin dashboard)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; 
    font-src 'self' data: https://cdn.jsdelivr.net https://use.fontawesome.com https://maxcdn.bootstrapcdn.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://use.fontawesome.com https://maxcdn.bootstrapcdn.com;
</IfModule>