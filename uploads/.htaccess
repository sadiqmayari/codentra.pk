## uploads/ — public read of static files only. NEVER execute uploaded
## code as PHP. This file is the second line of defence; the first is
## ImageUploader sanitising the filename + MIME on write.

Options -Indexes -ExecCGI

# Block any PHP-style execution on anything in this tree.
<FilesMatch "\.(php|phtml|phar|pht|phps|cgi|pl|py|sh|bash|asp|aspx|jsp)$">
    Require all denied
</FilesMatch>

# Hidden / dotfiles and .htaccess itself.
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Long-lived caching for the static assets we DO serve. Filename is
# random so cache invalidation is implicit (a new image gets a new name).
<FilesMatch "\.(?:webp|jpg|jpeg|png|gif|svg|avif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
